{
  "manifest_version": 3,
  "name": "TabVault – Session Manager",
  "short_name": "TabVault",
  "version": "0.3.0",
  "description": "Save, search and restore browser sessions with AI. Local-first. No account needed.",
  "permissions": ["tabs", "storage", "windows", "alarms", "contextMenus"],
  "host_permissions": ["https://api.anthropic.com/*"],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "TabVault",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "options_page": "dashboard/dashboard.html",
  "commands": {
    "save-session": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Save current window as a session"
    }
  }
}
